#!/usr/bin/env bash
# ccb-provider-activity-hook — bash launcher: resolve symlink, pick a CCB-compatible Python, exec ccb-provider-activity-hook.py
src="${BASH_SOURCE[0]}"
while [[ -L "$src" ]]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
SCRIPT_DIR="$(cd -P "$(dirname "$src")" && pwd)"
exec "$SCRIPT_DIR/_ccb-python" "$SCRIPT_DIR/ccb-provider-activity-hook.py" "$@"
