#!/usr/bin/env bash
# ctx-transfer — bash launcher: resolve symlink, pick a CCB-compatible Python, exec ctx-transfer.py
src="${BASH_SOURCE[0]}"
while [[ -L "$src" ]]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
SCRIPT_DIR="$(cd -P "$(dirname "$src")" && pwd)"
exec "$SCRIPT_DIR/_ccb-python" "$SCRIPT_DIR/ctx-transfer.py" "$@"
